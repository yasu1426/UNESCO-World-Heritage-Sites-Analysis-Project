      <aliases enabled='yes' />
      <column caption='Calculation2' datatype='integer' name='[Calculation_0649555303100416]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([area_hectares]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Danger or not' datatype='string' name='[Calculation_0735591392268288]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([danger_list],1)=&quot;Y&quot; THEN &quot;Current&quot;&#13;&#10;ELSE &quot;Not Current&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='string' name='[Calculation_0735591491948546]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if([date_end])=NULL then &quot;False&quot;&#13;&#10;else &quot;True&quot;&#13;&#10;end' />
      </column>
      <column caption='Danger sites' datatype='integer' name='[Calculation_0839496068620288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([danger])' />
      </column>
